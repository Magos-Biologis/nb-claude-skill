{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "PYBIN=$(command -v python3 || command -v python) && exec \"$PYBIN\" \"${CLAUDE_PLUGIN_ROOT}/scripts/nb-guard.py\""
          }
        ]
      }
    ]
  }
}
